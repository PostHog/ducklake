# PostgreSQL connection for DuckLake metadata
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ducklake
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=ducklake

# DuckLake data storage path
# Local: /path/to/local/ducklake_data
# S3: s3://your-bucket/ducklake_data
DUCKLAKE_DATA_PATH=/tmp/ducklake_data

# PostHog S3 source data
S3_BUCKET=sick-bucket-of-data
S3_PREFIX=events/

# AWS credentials (if not using instance profile/role)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1

# AWS Secrets Manager (for EMR Serverless)
# Secret name containing PostgreSQL password
# SECRET_NAME=your-secrets-manager-secret-name

# Spark configuration
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
SPARK_EXECUTOR_CORES=2

# Logging
LOG_LEVEL=INFO
